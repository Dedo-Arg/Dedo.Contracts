<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org"       value="https://api.nuget.org/v3/index.json" />
    <add key="github-dedo"     value="https://nuget.pkg.github.com/battistoniramiro/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <github-dedo>
      <add key="Username" value="battistoniramiro" />
      <!-- En CI: variable de entorno NUGET_AUTH_TOKEN -->
      <!-- En local: dotnet nuget update source github-dedo con un PAT -->
      <add key="ClearTextPassword" value="%NUGET_AUTH_TOKEN%" />
    </github-dedo>
  </packageSourceCredentials>
</configuration>
